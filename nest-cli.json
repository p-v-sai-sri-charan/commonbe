{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-gateway/src",
  "monorepo": true,
  "root": "apps/api-gateway",
  "compilerOptions": {
    "webpack": false,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json",
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger"]
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "payment-service": {
      "type": "application",
      "root": "apps/payment-service",
      "entryFile": "main",
      "sourceRoot": "apps/payment-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/payment-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "epidiet-service": {
      "type": "application",
      "root": "apps/epidiet-service",
      "entryFile": "main",
      "sourceRoot": "apps/epidiet-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/epidiet-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "ecom-service": {
      "type": "application",
      "root": "apps/ecom-service",
      "entryFile": "main",
      "sourceRoot": "apps/ecom-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ecom-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "temptatto-service": {
      "type": "application",
      "root": "apps/temptatto-service",
      "entryFile": "main",
      "sourceRoot": "apps/temptatto-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/temptatto-service/tsconfig.app.json",
        "plugins": ["@nestjs/swagger"]
      }
    },
    "ai": {
      "type": "library",
      "root": "libs/ai",
      "entryFile": "index",
      "sourceRoot": "libs/ai/src"
    }
  }
}
