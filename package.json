{
  "name": "backend",
  "version": "0.0.1",
  "description": "NestJS microservices monorepo: api-gateway, auth-service, user-service",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build api-gateway",
    "build:auth": "nest build auth-service",
    "build:user": "nest build user-service",
    "format": "prettier --write \"apps/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "start:gateway:dev": "nest start api-gateway --watch",
    "start:auth:dev": "nest start auth-service --watch",
    "start:user:dev": "nest start user-service --watch",
    "lint": "eslint \"apps/**/*.ts\" --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/mongoose": "^10.0.10",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/throttler": "^6.5.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "axios": "^1.7.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "google-auth-library": "^9.14.1",
    "mongoose": "^8.6.3",
    "openai": "^6.42.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.10.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
