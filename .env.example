PORT=3000
NODE_ENV=development

JWT_SECRET=super_secret_change_this
JWT_EXPIRES_IN=15m

AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002

AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002

AUTH_MONGO_URI=mongodb+srv://chinnu143313:4XERHOzaJyabd05y@cluster0.7vpavl6.mongodb.net/common-auth?retryWrites=true&w=majority/auth_db
USER_MONGO_URI=mongodb+srv://chinnu143313:4XERHOzaJyabd05y@cluster0.7vpavl6.mongodb.net/common-auth?retryWrites=true&w=majority/user_db

OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_HASH_SECRET=otp_hash_secret_change_this

GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Refresh tokens / sessions ---
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
REFRESH_TOKEN_HASH_SECRET=refresh_token_hash_secret_change_this

# --- SMS provider (auth-service) ---
# One of: console | msg91 | twilio | aws_sns | firebase
# "console" just logs the OTP — safe default for local dev.
SMS_PROVIDER=console

MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

FIREBASE_PROJECT_ID=

# --- Rate limiting (api-gateway) ---
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_DEFAULT_LIMIT=100
RATE_LIMIT_OTP_LIMIT=5
RATE_LIMIT_OTP_TTL_SECONDS=60

# --- RabbitMQ (events: auth-service -> notification-service) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EVENTS_QUEUE=auth_events_queue

# --- notification-service ---
NOTIFICATION_MONGO_URI=mongodb://localhost:27017/notification_db

# --- payment-service ---
PAYMENT_SERVICE_PORT=3004
PAYMENT_SERVICE_URL=http://localhost:3004
PAYMENT_MONGO_URI=mongodb://localhost:27017/payment_db

# Enable/disable each provider independently — this is the toggle requested:
# flip to true/false per provider, no code changes needed.
PAYMENT_RAZORPAY_ENABLED=true
PAYMENT_PAYU_ENABLED=false
PAYMENT_PHONEPE_ENABLED=false
PAYMENT_GPAY_ENABLED=false

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

PAYU_MERCHANT_KEY=
PAYU_SALT=

PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1

GPAY_MERCHANT_ID=
GPAY_MERCHANT_VPA=

# --- user-service ---
# Default AI token quota granted to a new profile (consumed by ecom-service's
# AI features today; epidiet-service's AI coach will draw from it too).
AI_TOKEN_LIMIT_DEFAULT=1000

# --- Shared AI provider toggle (libs/ai) ---
# One of: claude | openai. Used by epidiet-service's AI coach today; any
# future service (ecom-service) imports the same @app/ai module.
AI_PROVIDER=claude

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- epidiet-service ---
EPIDIET_SERVICE_PORT=3005
EPIDIET_SERVICE_URL=http://localhost:3005
EPIDIET_MONGO_URI=mongodb://localhost:27017/epidiet_db

# --- ecom-service ---
ECOM_SERVICE_PORT=3006
ECOM_SERVICE_URL=http://localhost:3006
ECOM_MONGO_URI=mongodb://localhost:27017/ecom_db

# BYOK (Bring Your Own Key) — AES-256-CBC key for encrypting creator API keys.
# Must be exactly 64 hex chars (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BYOK_ENCRYPTION_KEY=byok_encryption_key_32bytes_hexhex_change_this_00000000000000

# Cloudinary (for design image uploads — client uploads directly using the signed URL)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- temptatto-service ---
# Independent from ecom-service: own DB, own cart/orders/marketplace, no shared code.
TEMPTATTO_SERVICE_PORT=3007
TEMPTATTO_SERVICE_URL=http://localhost:3007
TEMPTATTO_MONGO_URI=mongodb://localhost:27017/temptatto_db
